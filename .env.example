# NBAforecast — environment variables (copy to .env, never commit .env)
# Prefix: NBAF_  (see engineering-standards.md §5)

# ── Postgres ──────────────────────────────────────────────────────────────
NBAF_POSTGRES_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nbaforecast

# ── Redis ─────────────────────────────────────────────────────────────────
NBAF_REDIS_URL=redis://localhost:6379/0

# ── MinIO / S3 ────────────────────────────────────────────────────────────
NBAF_S3_ENDPOINT_URL=http://localhost:9000
NBAF_S3_ACCESS_KEY=minioadmin
NBAF_S3_SECRET_KEY=minioadmin
NBAF_S3_BUCKET=nbaforecast

# ── MLflow ────────────────────────────────────────────────────────────────
NBAF_MLFLOW_TRACKING_URI=http://localhost:5000
# MLflow's boto3 client needs AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY.
# Settings.configure_mlflow_env() maps NBAF_S3_* → AWS_* at startup,
# so no bare AWS_* vars are needed here.

# ── Ingestion (nba_api / pbpstats) ──────────────────────────────────────────
# stats.nba.com is rate-limited and header-sensitive: throttle + retry + real UA.
NBAF_INGEST_THROTTLE_SECONDS=0.6
NBAF_INGEST_REQUEST_TIMEOUT=60
NBAF_INGEST_MAX_RETRIES=5
# NBAF_INGEST_USER_AGENT=Mozilla/5.0 ...   # defaults to a realistic Chrome UA
NBAF_PBPSTATS_CACHE_DIR=data/pbpstats_cache
NBAF_PARQUET_ROOT=data/silver   # root of the partitioned silver Parquet store
NBAF_INGEST_DAILY_CRON=0 6 * * *          # nightly ingest schedule (cron)
NBAF_INGEST_TIMEZONE=America/New_York     # cron timezone (default 6am ET)
NBAF_INGEST_CONCURRENCY=1                 # max concurrent stats.nba.com calls

# ── App ───────────────────────────────────────────────────────────────────
NBAF_ENV=development          # development | test | production
NBAF_LOG_LEVEL=INFO
NBAF_API_HOST=0.0.0.0
NBAF_API_PORT=8000
