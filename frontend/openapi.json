        ],
        "summary": "Get Game Prediction Full Explanation",
        "operationId": "get_game_prediction_full_explanation_api_v1_games__game_id__prediction_full_explanation_get",
        "parameters": [
          {
            "name": "game_id",
            "in": "path",
