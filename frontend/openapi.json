  "components": {
    "schemas": {
      "Contribution": {
        "properties": {
          "feature": {
            "type": "string",
            "title": "Feature"
          },
          "display_label": {
            "type": "string",
            "title": "Display Label"
          },
          "raw_value": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "integer"
              },
              {
                "type": "string"
              },
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Raw Value"
          },
          "formatted_value": {
            "type": "string",
            "title": "Formatted Value"
          },
          "contribution": {
            "type": "number",
            "title": "Contribution"
          },
          "direction": {
            "type": "string",
            "enum": [
              "up",
              "down"
            ],
            "title": "Direction"
          }
        },
        "type": "object",
        "required": [
          "feature",
          "display_label",
          "raw_value",
          "formatted_value",
          "contribution",
          "direction"
        ],
        "title": "Contribution",
        "description": "One feature's signed contribution to a single prediction.\n\n``display_label``/``formatted_value`` are placeholders (the raw feature name and\n``str(raw_value)``) until T2.11's humanizer decorates them \u2014 see\n``explain/explainers.py``'s module docstring."
      },
      "Explanation": {
        "properties": {
          "baseline": {
            "type": "number",
            "title": "Baseline"
          },
          "prediction": {
            "type": "number",
            "title": "Prediction"
          },
          "contributions": {
            "items": {
              "$ref": "#/components/schemas/Contribution"
            },
            "type": "array",
            "title": "Contributions"
          },
          "units": {
            "$ref": "#/components/schemas/ExplanationUnits"
          },
          "notes": {
            "type": "string",
            "title": "Notes"
          }
        },
        "type": "object",
        "required": [
          "baseline",
          "prediction",
          "contributions",
          "units",
          "notes"
        ],
        "title": "Explanation",
        "description": "The \u00a75 explanation contract \u2014 every model head's ``explain()`` returns this shape.\n\n``contributions`` is sorted by ``abs(contribution)`` descending (\u00a75: \"sorted by magnitude\")\nso the frontend can show the top-N headline drivers with the rest expandable. Additivity\nholds in whichever ``units`` the explanation was computed in:\n``sum(c.contribution for c in contributions) == prediction - baseline`` (T2.12 verifies this\nfor the SHAP path within floating-point tolerance)."
      },
      "ExplanationUnits": {
        "type": "string",
        "enum": [
          "probability_points",
          "log_odds",
          "points",
          "rebounds",
          "assists",
          "three_pointers_made"
        ],
        "title": "ExplanationUnits",
        "description": "What scale ``Explanation.baseline``/``prediction``/``Contribution.contribution`` are in."
      },
      "GameDetail": {
        "properties": {
          "game_id": {
            "type": "string",
            "title": "Game Id"
          },
          "season": {
            "type": "string",
            "title": "Season"
          },
          "game_date": {
            "type": "string",
            "format": "date",
            "title": "Game Date"
          },
          "home_team": {
            "$ref": "#/components/schemas/TeamSummary"
          },
          "away_team": {
            "$ref": "#/components/schemas/TeamSummary"
          },
          "home_score": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Home Score"
          },
          "away_score": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Away Score"
          },
          "status": {
            "type": "string",
            "title": "Status"
          },
          "game_datetime": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Game Datetime"
          },
          "num_periods": {
            "type": "integer",
            "title": "Num Periods"
          }
        },
        "type": "object",
        "required": [
          "game_id",
          "season",
          "game_date",
          "home_team",
          "away_team",
          "home_score",
          "away_score",
          "status",
          "game_datetime",
          "num_periods"
        ],
        "title": "GameDetail",
        "description": "Full game record \u2014 backend-api.md \u00a73 ``GET /games/{game_id}``."
      },
      "GamePrediction": {
        "properties": {
          "game_id": {
            "type": "string",
            "title": "Game Id"
          },
          "win_prob": {
            "type": "number",
            "title": "Win Prob"
          },
          "margin": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Margin"
          },
          "total": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Total"
          },
          "market": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Market"
          },
          "explanation": {
            "$ref": "#/components/schemas/Explanation"
          }
        },
        "type": "object",
        "required": [
          "game_id",
          "win_prob",
          "explanation"
        ],
        "title": "GamePrediction",
        "description": "backend-api.md \u00a74 ``GamePrediction``.\n\n``margin``/``total`` are reserved for the regressor heads (T3.1, M3 scope) \u2014 ``None`` until\nthen. ``market`` is reserved for the v2 odds-comparison feature (modeling.md \u00a710)."
      },
      "GameSummary": {
        "properties": {
          "game_id": {
            "type": "string",
            "title": "Game Id"
          },
          "season": {
            "type": "string",
            "title": "Season"
          },
          "game_date": {
            "type": "string",
            "format": "date",
            "title": "Game Date"
          },
          "home_team": {
            "$ref": "#/components/schemas/TeamSummary"
          },
          "away_team": {
            "$ref": "#/components/schemas/TeamSummary"
          },
          "home_score": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Home Score"
          },
          "away_score": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Away Score"
          },
          "status": {
            "type": "string",
            "title": "Status"
          }
        },
        "type": "object",
        "required": [
          "game_id",
          "season",
          "game_date",
          "home_team",
          "away_team",
          "home_score",
          "away_score",
          "status"
        ],
        "title": "GameSummary",
        "description": "One row of a games list \u2014 backend-api.md \u00a73 ``GET /games``."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "Page_GameSummary_": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/GameSummary"
            },
            "type": "array",
            "title": "Items"
          },
          "total": {
            "type": "integer",
            "title": "Total"
          },
          "page": {
            "type": "integer",
            "title": "Page"
          },
          "page_size": {
            "type": "integer",
            "title": "Page Size"
          }
        },
        "type": "object",
        "required": [
          "items",
          "total",
          "page",
          "page_size"
        ],
        "title": "Page[GameSummary]"
      },
      "TeamSummary": {
        "properties": {
          "team_id": {
            "type": "integer",
            "title": "Team Id"
          },
          "abbreviation": {
            "type": "string",
            "title": "Abbreviation"
          },
          "full_name": {
            "type": "string",
            "title": "Full Name"
          }
        },
        "type": "object",
        "required": [
          "team_id",
          "abbreviation",
          "full_name"
        ],
        "title": "TeamSummary",
        "description": "The minimal team identity embedded in a game response."
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}
